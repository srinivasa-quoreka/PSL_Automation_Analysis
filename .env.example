# Jira connection settings
JIRA_BASE_URL=https://your-jira-instance.example.com
JIRA_USERNAME=your-email@example.com
JIRA_PASSWORD=your-password-or-api-token

# JQL to fetch test cases (adjust to your project / issue type)
JIRA_JQL=project = "project in (QA-Automation) AND issuetype = Test"

# Which test management tool stores your steps:
#   xray         -> Xray (default; uses /rest/raven/1.0/api/test/{key}/steps)
#   zephyr_scale -> Zephyr Scale (uses /rest/atm/1.0/testcase/{key})
#   custom_field -> steps stored directly on the issue in a custom field
TEST_TOOL=xray

# Only used when TEST_TOOL=custom_field. The custom field id holding steps
# (e.g. customfield_10100). The field is expected to be a list / array.
STEPS_CUSTOM_FIELD=customfield_10100

# Cache TTL in seconds (0 disables caching)
CACHE_TTL=300

# Max test cases to fetch (safety guard)
MAX_RESULTS=2000
